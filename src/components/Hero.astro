---
import { site, stats } from "@/data/site";
---

<section
  id="top"
  class="relative overflow-hidden bg-brand-deep text-on-deep"
  aria-labelledby="hero-heading"
>
  <!-- Atmosphere: glass-pane grid + accent glow -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.07]"
    style="background-image:linear-gradient(var(--color-on-deep) 1px,transparent 1px),linear-gradient(90deg,var(--color-on-deep) 1px,transparent 1px);background-size:64px 64px;"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -right-32 -top-32 size-[28rem] rounded-full bg-brand-accent/25 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-6xl gap-12 px-5 py-[clamp(4rem,3rem+8vw,8rem)] lg:grid-cols-[1.15fr_0.85fr] lg:items-center"
  >
    <div>
      <p
        class="mb-5 inline-flex items-center gap-2 rounded-full border border-on-deep/20 px-3 py-1 text-xs font-500 tracking-wide text-brand-glass uppercase"
      >
        <span class="size-1.5 rounded-full bg-brand-accent"></span>
        Meisterbetrieb · {site.region} · seit {site.since}
      </p>

      <h1
        id="hero-heading"
        class="font-display text-[length:var(--text-hero)] leading-[0.95] font-600"
      >
        {site.tagline}
      </h1>

      <p class="mt-6 max-w-xl text-lg text-on-deep/75">
        {site.description}
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href="#kontakt"
          class="rounded-full bg-brand-accent px-6 py-3 font-600 text-brand-deep shadow-lg shadow-black/20 transition-transform hover:-translate-y-0.5"
        >
          Kostenloses Aufmaß anfragen
        </a>
        <a
          href={site.phoneHref}
          class="rounded-full border border-on-deep/25 px-6 py-3 font-500 text-on-deep transition-colors hover:bg-on-deep/10"
        >
          {site.phone}
        </a>
      </div>
    </div>

    <!-- Glass card stack -->
    <div class="relative hidden lg:block" aria-hidden="true">
      <div
        class="absolute inset-0 translate-x-6 translate-y-6 rounded-[var(--radius-card)] border border-on-deep/15"
      >
      </div>
      <div
        class="relative rounded-[var(--radius-card)] border border-on-deep/15 bg-on-deep/[0.06] p-7 backdrop-blur-sm"
      >
        <dl class="grid grid-cols-2 gap-x-6 gap-y-7">
          {
            stats.map((s) => (
              <div>
                <dt class="font-display text-4xl font-600 text-brand-accent">
                  {s.value}
                </dt>
                <dd class="mt-1 text-sm text-on-deep/70">{s.label}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>
